# Spotify Client ID
# Uzyskaj w:
# https://spotify.com
SPOTIFY_CLIENT_ID=be041ca14c8847e4805b5ee4772a8239

# Spotify Client Secret
# Uzyskaj w:
# https://spotify.com
SPOTIFY_CLIENT_SECRET=2006400ba5b140b983776fc08dc65d70

# Spotify Redirect URI
# Powinna wskazywać:
# http://localhost:8080/callback
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# Port HTTP aplikacji
SERVER_PORT=:8080

# Klucz szyfrujący sesje użytkowników
# Zmień tę wartość w środowisku produkcyjnym na losowy, silny ciąg znaków
SESSION_SECRET=super_secret_key_change_me