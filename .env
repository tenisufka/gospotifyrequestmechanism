# Spotify Client ID
# Uzyskaj w:
# https://spotify.com
SPOTIFY_CLIENT_ID=
# Spotify Client Secret
# Uzyskaj w:
# https://spotify.com
SPOTIFY_CLIENT_SECRET=

# Spotify Redirect URI
# Powinna wskazywać:
# http://localhost:8080/callback 
# albo inny adres, który skonfigurujesz w Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=
# Port HTTP aplikacji
SERVER_PORT=:

# Klucz szyfrujący sesje użytkowników
# Zmień tę wartość w środowisku produkcyjnym na losowy, silny ciąg znaków
SESSION_SECRET=