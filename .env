# Spotify Client ID
# Uzyskaj w:
# https://spotify.com
SPOTIFY_CLIENT_ID=01a392b8a4ad41278a6b7027384cd664

# Spotify Client Secret
# Uzyskaj w:
# https://spotify.com
SPOTIFY_CLIENT_SECRET=0cdea1bc11e64f73ad165be99bf79380

# Spotify Redirect URI
# Powinna wskazywać:
# http://localhost:8080/callback albo https://chowder-unwritten-iciness.ngrok-free.dev/callback 
# albo inny adres, który skonfigurujesz w Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=https://chowder-unwritten-iciness.ngrok-free.dev/callback
# Port HTTP aplikacji
SERVER_PORT=:8080

# Klucz szyfrujący sesje użytkowników
# Zmień tę wartość w środowisku produkcyjnym na losowy, silny ciąg znaków
SESSION_SECRET=super_secret_key_change_me